{
  "name": "medevsmaker",
  "version": "1.0.0",
  "description": "AI Video Director — generate Remotion videos from simple ideas",
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render",
    "build": "remotion render src/index.ts",
    "upgrade": "remotion upgrade",
    "manifest": "node --experimental-strip-types scripts/tts/generate-manifest.ts",
    "transcript": "node --experimental-strip-types --env-file=.env scripts/tts/generate-transcript.ts",
    "voiceover": "node --experimental-strip-types --env-file=.env scripts/tts/generate-audio.ts"
  },
  "dependencies": {
