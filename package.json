    "@remotion/cli": "4.0.427",
    "@remotion/google-fonts": "4.0.427",
    "@remotion/light-leaks": "^4.0.427",
    "@remotion/media": "4.0.427",
    "@remotion/motion-blur": "^4.0.427",
    "@remotion/noise": "^4.0.427",
    "@remotion/paths": "^4.0.427",
    "@remotion/shapes": "^4.0.427",
    "@remotion/transitions": "4.0.427",
    "edge-tts-universal": "^1.3.3",
    "msedge-tts": "^2.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.427",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config": "4.0.427",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
